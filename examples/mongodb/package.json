{
    "name": "@graphql-pagination/example-mongodb",
    "private": true,
    "description": "Example demonstrating how to use @graphql-pagination/core with an MonoDB datasource.",
    "version": "1.1.1",
    "license": "MIT",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "engines": {
        "node": ">=20"
    },
    "scripts": {
        "build": "tsc",
        "codegen": "graphql-codegen -r ts-node/register",
        "start": "node dist/index.js",
        "dev": "nodemon --watch \"src/**\" --ext \"ts,json\" --exec \"ts-node src/index.ts\""
    },
    "dependencies": {
        "@apollo/server": "^5.5.0",
        "@graphql-pagination/mongodb": "^1.3.1",
        "graphql": "^16.11.0",
        "graphql-tag": "2.12.6",
        "mongodb": "^6.21.0",
        "mongodb-memory-server": "^10.4.3"
    },
    "devDependencies": {
        "@graphql-codegen/cli": "^3.3.1",
        "@graphql-codegen/typescript": "^3.0.4",
        "@graphql-codegen/typescript-resolvers": "^3.2.1",
        "@types/jest": "^29.5.14",
        "@types/node": "^18.19.130",
        "ts-jest": "^29.4.4",
        "ts-node": "^10.9.1",
        "typescript": "^5.9.3"
    }
}
